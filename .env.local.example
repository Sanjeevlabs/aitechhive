# ============================================================
# AITechHive v2 — environment variables
# Copy to .env.local for local dev. Set in GitHub Secrets + Cloudflare Pages for prod.
# ============================================================

# ===== LLM PROVIDER (one-click swap) =====
# Choose ONE: anthropic | openai | gemini | groq | deepseek | openrouter
LLM_PROVIDER=anthropic

# API key for the chosen provider
LLM_API_KEY=sk-ant-...

# Optional: override the default model for the chosen provider
# Defaults:
#   anthropic  → claude-haiku-4-5
#   openai     → gpt-4o-mini
#   gemini     → gemini-2.0-flash
#   groq       → llama-3.3-70b-versatile
#   deepseek   → deepseek-chat
#   openrouter → anthropic/claude-haiku-4-5
# LLM_MODEL=gemini-2.0-flash

# ===== WEB SEARCH FALLBACK =====
# Optional. Used by gemini/groq/deepseek/openrouter (which don't have native search).
# Free 2K queries/month. Get key at https://brave.com/search/api
# BRAVE_API_KEY=

# ===== SUPABASE =====
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...  # server-only, never client

# ===== ANALYTICS =====
# Optional. Free at plausible.io
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=aitechhive.com

# ===== APP =====
NEXT_PUBLIC_APP_URL=https://aitechhive.com
